doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title= title
    link(rel="icon" type="image/x-icon" href="/images/Web.png")
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet")
    link(rel="stylesheet" href="/css/style.css")
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css")
  body
    // Navbar
    nav.navbar.navbar-expand-lg.navbar-dark
      .container
        a.navbar-brand(href="/")
          img(src="/images/LogoVictorRuiz.png" alt="Victor Ruiz Voices" height="60")
        button.navbar-toggler(type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav")
          span.navbar-toggler-icon
        #navbarNav.collapse.navbar-collapse
          ul.navbar-nav.ms-auto.align-items-center
            li.nav-item
              a.nav-link(href="/demos") Demos
            li.nav-item
              a.nav-link(href="/trabajos-previos") Trabajos Previos
            li.nav-item
              a.nav-link(href="/sobre-mi") Sobre mí
            li.nav-item
              a.nav-link.contact-email(href="mailto:contacto@victoruizvoices.com")
                span.highlight contacto
                | @victoruizvoices.com
    
    // Contenido
    block content
    
    // Footer
    footer.footer
      .container
        .row.align-items-center.py-4
          .col-md-4.text-center.text-md-start.mb-3.mb-md-0
            .social-icons
              a(href="https://www.instagram.com/victoruizvoices/" target="_blank" rel="noopener noreferrer")
                i.bi.bi-instagram
              a(href="https://www.linkedin.com/in/victoruizvoices/" target="_blank" rel="noopener noreferrer")
                i.bi.bi-linkedin
              a(href="https://www.tiktok.com/@victoruizvoices" target="_blank" rel="noopener noreferrer")
                i.bi.bi-tiktok
              a(href="https://doblaje.fandom.com/es/wiki/Victor_Alan_Ruiz" target="_blank" rel="noopener noreferrer")
                i.bi.bi-book
          .col-md-4.text-center.mb-3.mb-md-0
            img(src="/images/LogoVictorRuiz.png" alt="Victor Ruiz Voices" height="100")
          .col-md-4.text-center.text-md-end
            a.contact-email(href="mailto:contacto@victoruizvoices.com")
              span.highlight contacto
              | @victoruizvoices.com

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js")